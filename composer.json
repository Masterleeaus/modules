{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/vue-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "./plugins/filament-chatbot",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "package",
            "package": {
                "name": "tomatophp/filament-twilio",
                "version": "1.0.1",
                "source": {
                    "url": "https://github.com/tomatophp/filament-twilio.git",
                    "type": "git",
                    "reference": "master"
                },
                "autoload": {
                    "psr-4": {
                        "TomatoPHP\\FilamentTwilio\\": "src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "TomatoPHP\\FilamentTwilio\\FilamentTwilioServiceProvider"
                        ]
                    }
                },
                "require": {
                    "php": "^8.1|^8.2|^8.4",
                    "tomatophp/console-helpers": "^1.1",
                    "twilio/sdk": "^8.2"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "tomatophp/filament-payments",
                "version": "1.0.20",
                "source": {
                    "url": "https://github.com/tomatophp/filament-payments.git",
                    "type": "git",
                    "reference": "master"
                },
                "autoload": {
                    "psr-4": {
                        "TomatoPHP\\FilamentPayments\\": "src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "TomatoPHP\\FilamentPayments\\FilamentPaymentsServiceProvider"
                        ]
                    }
                },
                "require": {
                    "php": "^8.1|^8.4",
                    "tomatophp/console-helpers": "^1.0",
                    "stripe/stripe-php": "^16.5|^20.0",
                    "tomatophp/filament-translation-component": "^1.0|^4.0"
                }
            }
        }
    ],
    "require": {
        "php": "^8.4",
        "emmanpbarrameda/filament-take-picture-field": "^1.2",
        "filament/filament": "^4.0",
        "filament/spatie-laravel-media-library-plugin": "^4.0",
        "filament/spatie-laravel-settings-plugin": "^4.0",
        "guava/calendar": "^2.0",
        "inertiajs/inertia-laravel": "^2.0",
        "kenepa/banner": "^1.0",
        "laravel/fortify": "^1.30",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.10",
        "laravel/tinker": "^2.10.1",
        "laravel/wayfinder": "^0.1.9",
        "redberry/page-builder-plugin": "^2.0",
        "sentry/sentry-laravel": "^4.25",
        "solution-forest/filament-header-select": "^0.0.1",
        "spatie/laravel-permission": "^7.0",
        "stripe/stripe-php": "^20.0",
        "symfony/sendgrid-mailer": "^8.0",
        "titanzero/filament-chatbot": "@dev",
        "tomatophp/filament-cms": "^4.0",
        "tomatophp/filament-invoices": "^4.0",
        "tomatophp/filament-payments": "1.0.20",
        "tomatophp/filament-settings-hub": "^4.0",
        "tomatophp/filament-twilio": "1.0.1",
        "twilio/sdk": "^8.11"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "laravel/telescope": "^5.20",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "@php artisan titan:module:verify --all",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "dev:ssr": [
            "npm run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php -d memory_limit=512M vendor/bin/pest"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
